weapons: [
  {
    name: turret-ja
    localizedName: Basic Pierce Tank Weapon
    length: 20
    reload: 60
    shootCone: 15
    mirror: false
      x: 0
      y: 0
    continuous: true
    shootSound: shootDuo
    bullet: {
      type: ContinuousLaserBulletType
      damage: 50
      length: 100
      width: 4
  
      # Visual colors of the laser beam (Ice blue themes)
      colors: [008080, 00bfbf, 00ffff]

      pierce: true
      pierceCap: 3  
  
      # Optional cosmetic effects
      hitEffect: none
      smokeEffect: none
    }
  }
