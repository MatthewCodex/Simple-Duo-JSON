type: PowerTurret
name: Basic Pierce Turret
description: Shoots piercing projectiles.
hasPower: true
size: 1
health: 800
range: 100
reload: 60
category: turret

# Configure power requirements
consumes: {
  power: 1
}

# Define the laser properties
shootType: {
  type: ContinuousLaserBulletType
  damage: 50
  length: 100
  width: 4
  
  # Visual colors of the laser beam (Ice blue themes)
  colors: [008080, 00bfbf, 00ffff]

  pierce: true
  pierceCap: 3  
  
  # Optional cosmetic effects
  hitEffect: none
  smokeEffect: none
}

requirements: [
  copper/150
  lead/120
  silicon/80
  titanium/50
]
research: arc

drawer: {
  type: DrawTurret
  basePrefix: "turret-"
}
