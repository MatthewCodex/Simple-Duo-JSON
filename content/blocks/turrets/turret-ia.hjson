type: ItemTurret
name: Basic Blast Turret
description: Functions the same way as a homing turret, except it blasts enemies. Uses Lead as ammo.
health: 800
size: 1
recoil: 0.5
shootY: 3
reload: 60
range: 50
shootCone: 15
ammoUseEffect: casing1
inaccuracy: 5
rotateSpeed: 20
targetGround: true
targetAir: true
researchCostMultiplier: 0.5

consumes: {
  coolant: {
    amount: 0.1
  }
}

ammoTypes: {
  lead: {
    speed: 4
    damage: 25
    lifetime: 100
    homingPower: 0.1
    homingRange: 200
    width: 4
    height: 4
    shootEffect: shootBig
    smokeEffect: shootSmokeSquare
    hitEffect: blastExplosion
    shootSound: shootArtillery
    hitSound: blockExplode3
    despawnSound: blockExplode3
    status: blasted
	frontColor: ffffff
	backColor: ff0000
	ammoMultiplier: 3
  }
}

shoot: {
  type: ShootAlternate
  shots: 1
  spread: 3
  shotDelay: 0
}
 
requirements: [
copper/700
lead/500
graphite/150
]
category: turret
research: duo
 
drawer: {
  type: DrawTurret
  basePrefix: "turret-"
