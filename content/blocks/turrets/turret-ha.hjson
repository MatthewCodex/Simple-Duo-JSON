type: PowerTurret
name: Basic Freeze Turret
description: Freezes enemies.
hasPower: true
size: 1
health: 800
range: 50
reload: 10
category: turret

# Configure power requirements
consumes: {
  power: 1
}

# Define the laser properties
shootType: {
  type: ContinuousLaserBulletType
  damage: 4
  length: 75
  width: 4
  
  # Visual colors of the laser beam (Ice blue themes)
  colors: [00ffff, 80ffff, ffffff]
  
  # Apply the freezing debuff
  status: freezing
  statusDuration: 120
  
  # Optional cosmetic effects
  hitEffect: freezing
  smokeEffect: none
}

requirements: [
  copper/150
  lead/120
  silicon/80
  titanium/50
]
research: arc

drawer: {
  type: DrawTurret
  basePrefix: "turret-"
}
