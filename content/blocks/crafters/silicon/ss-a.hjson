type: GenericCrafter
name: T1 Silicon Smelter
description: Turns sand and coal into silicon. Glows when active.
size: 2
hasItems: true
craftTime: 60

# Base light settings for the block
emitLight: true
lightRadius: 60

consumes: {
  items: [
    coal/1
    sand/1
  ]
}

requirements: [
silicon/25
copper/25
lead/25
]

outputItem: silicon/2

# This section controls the visual glow during crafting
drawer: {
  type: DrawMulti
  drawers: [
    {
      type: DrawDefault
    }
    {
      type: DrawFlame
      flameColor: ffef99ff
    }
  ]
}

category: crafting
research: silicon