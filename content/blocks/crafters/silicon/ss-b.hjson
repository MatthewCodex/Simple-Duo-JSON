type: GenericCrafter
name: T2 Silicon Smelter
description: Turns sand and coal into silicon. Glows when active.
size: 2
hasItems: true
craftTime: 45

# Base light settings for the block
emitLight: true
lightRadius: 60

consumes: {
  items: [
    coal/1
    sand/1
  ]
}

requirements: [
silicon/50
copper/50
lead/50
]

outputItem: silicon/3

# This section controls the visual glow during crafting
drawer: {
  type: DrawMulti
  drawers: [
    {
      type: DrawDefault
    }
    {
      type: DrawLight
    }
  ]
}

category: crafting
research: ss-a