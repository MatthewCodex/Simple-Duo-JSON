type: GenericCrafter
name: T3 Silicon Smelter
description: Turns sand and coal into silicon. Glows when active.
size: 2
hasItems: true
craftTime: 30

# Base light settings for the block
emitLight: true
lightRadius: 60

consumes: {
  items: [
    coal/1
    sand/1
  ]
}

requirements: [
silicon/100
copper/100
lead/100
]

outputItem: silicon/4

# This section controls the visual glow during crafting
drawer: {
  type: DrawMulti
  drawers: [
    {
      type: DrawDefault
    }
    {
      type: DrawLight
    }
  ]
}

category: crafting
research: ss-b